{
  "name": "Secrets Manager",
  "label": "Secrets Manager",
  "service_id": "secrets_mgr",
  "version": "1.0.0",
  "description": "Manages secrets and credentials for connected resources",
  "connected_resources": [
    {
      "type": "dynamodb_table",
      "label": "MongoDB (Catalogue/User)",
      "config": {
        "name": "MongoDB (Catalogue/User)",
        "table_name": "mongodb_catalogue_user_secrets",
        "billing_mode": "PAY_PER_REQUEST",
        "hash_key": "secret_id",
        "range_key": "version",
        "attributes": [
          {
            "name": "secret_id",
            "type": "S"
          },
          {
            "name": "version",
            "type": "S"
          }
        ],
        "ttl": {
          "enabled": true,
          "attribute_name": "expires_at"
        },
        "encryption": {
          "enabled": true,
          "type": "AWS_OWNED_CMK"
        },
        "point_in_time_recovery": true
      }
    }
  ]
}